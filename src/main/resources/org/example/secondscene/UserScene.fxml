<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.secondscene.userController"
      styleClass="admin-bg"
      stylesheets="@styles.css"
      prefWidth="800" prefHeight="580">

    <!-- Top bar -->
    <HBox styleClass="topbar" alignment="CENTER_LEFT" spacing="12">
        <Label text="UniBook" styleClass="title-label"/>
        <Label text="USER" styleClass="badge"/>
        <HBox HBox.hgrow="ALWAYS"/>
        <Label fx:id="userLabel" styleClass="subtitle-label"/>
        <Button fx:id="logoutButton" text="Sign Out" onAction="#logout" styleClass="btn-danger"/>
    </HBox>

    <!-- Status message -->
    <HBox>
        <padding><Insets top="10" left="24" right="24"/></padding>
        <Label fx:id="statusLabel"/>
    </HBox>

    <!-- Main content: two panels side by side -->
    <HBox VBox.vgrow="ALWAYS" spacing="0">

        <!-- Left: Available Events -->
        <VBox styleClass="form-panel" HBox.hgrow="ALWAYS" spacing="12">
            <padding><Insets top="16" bottom="16" left="20" right="20"/></padding>

            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="AVAILABLE EVENTS" styleClass="section-label"/>
            </HBox>

            <ListView fx:id="eventListView" VBox.vgrow="ALWAYS" styleClass="list-view"/>

            <Button text="Register for Selected Event" onAction="#handleRegister"
                    maxWidth="Infinity" styleClass="btn-primary"/>
        </VBox>

        <!-- Right: My Registrations -->
        <VBox HBox.hgrow="ALWAYS" spacing="12">
            <padding><Insets top="16" bottom="16" left="20" right="20"/></padding>

            <HBox alignment="CENTER_LEFT">
                <Label text="MY REGISTRATIONS" styleClass="section-label"/>
            </HBox>

            <ListView fx:id="registrationListView" VBox.vgrow="ALWAYS" styleClass="list-view"/>

            <Button text="Cancel Registration" onAction="#handleUnregister"
                    maxWidth="Infinity" styleClass="btn-secondary"/>
        </VBox>
    </HBox>
</VBox>
